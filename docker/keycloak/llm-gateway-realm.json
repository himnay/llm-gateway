{
  "realm": "llm-gateway",
  "enabled": true,
  "sslRequired": "none",
  "accessTokenLifespan": 900,
  "roles": {
    "realm": [
      { "name": "gateway-user", "description": "Can call LLM Gateway inference endpoints" },
      { "name": "gateway-admin", "description": "Elevated gateway role, reserved for future admin-only endpoints" }
    ]
  },
  "requiredActions": [
    { "alias": "CONFIGURE_TOTP", "name": "Configure OTP", "providerId": "CONFIGURE_TOTP", "enabled": true, "defaultAction": false, "priority": 10 },
    { "alias": "TERMS_AND_CONDITIONS", "name": "Terms and Conditions", "providerId": "TERMS_AND_CONDITIONS", "enabled": false, "defaultAction": false, "priority": 20 },
    { "alias": "UPDATE_PASSWORD", "name": "Update Password", "providerId": "UPDATE_PASSWORD", "enabled": true, "defaultAction": false, "priority": 30 },
    { "alias": "UPDATE_PROFILE", "name": "Update Profile", "providerId": "UPDATE_PROFILE", "enabled": true, "defaultAction": false, "priority": 40 },
    { "alias": "VERIFY_EMAIL", "name": "Verify Email", "providerId": "VERIFY_EMAIL", "enabled": true, "defaultAction": false, "priority": 50 },
    { "alias": "update_user_locale", "name": "Update User Locale", "providerId": "update_user_locale", "enabled": true, "defaultAction": false, "priority": 1000 }
  ],
  "clients": [
    {
      "clientId": "llm-gateway-client",
      "name": "LLM Gateway (machine-to-machine)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "llm-gateway-dev-secret",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false,
      "redirectUris": [],
      "webOrigins": []
    },
    {
      "clientId": "llm-chat-agent-client",
