<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <springProperty scope="context" name="APP_NAME" source="spring.application.name" defaultValue="llm-gateway"/>

    <!-- ─────────────────────────────────────────────────────────────────
         Console appender – human-readable with trace correlation IDs
         ───────────────────────────────────────────────────────────────── -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>
                %d{yyyy-MM-dd HH:mm:ss.SSS} %highlight(%-5level) [%thread] [%boldCyan(traceId=%X{traceId:-none})] [%boldYellow(spanId=%X{spanId:-none})] [reqId=%X{requestId:-none}] [provider=%X{provider:-}] %cyan(%logger{50}) - %msg%n
            </pattern>
        </encoder>
    </appender>

    <!-- ─────────────────────────────────────────────────────────────────
         JSON File appender – structured logs for log aggregators
         ───────────────────────────────────────────────────────────────── -->
    <appender name="JSON_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/llm-gateway.json</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/llm-gateway.%d{yyyy-MM-dd}.%i.json.gz</fileNamePattern>
            <timeBasedFileNamingAndTriggeringPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
                <maxFileSize>100MB</maxFileSize>
            </timeBasedFileNamingAndTriggeringPolicy>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>{"app":"${APP_NAME}"}</customFields>
            <includeMdcKeyName>traceId</includeMdcKeyName>
            <includeMdcKeyName>spanId</includeMdcKeyName>
            <includeMdcKeyName>requestId</includeMdcKeyName>
            <includeMdcKeyName>provider</includeMdcKeyName>
            <includeMdcKeyName>sessionId</includeMdcKeyName>
        </encoder>
    </appender>

    <!-- ─────────────────────────────────────────────────────────────────
         Async wrapper (non-blocking log writes)
         ───────────────────────────────────────────────────────────────── -->
    <appender name="ASYNC_CONSOLE" class="ch.qos.logback.classic.AsyncAppender">
        <discardingThreshold>0</discardingThreshold>
        <queueSize>512</queueSize>
        <appender-ref ref="CONSOLE"/>
    </appender>

    <!-- ─────────────────────────────────────────────────────────────────
         Logger configuration
         ───────────────────────────────────────────────────────────────── -->
    <root level="INFO">
        <appender-ref ref="ASYNC_CONSOLE"/>
    </root>

    <logger name="com.llm.gateway" level="DEBUG" additivity="false">
        <appender-ref ref="ASYNC_CONSOLE"/>
    </logger>

    <logger name="org.springframework.web" level="INFO"/>
    <logger name="io.lettuce" level="WARN"/>
    <logger name="reactor.netty" level="WARN"/>

    <springProfile name="prod">
        <root level="WARN">
            <appender-ref ref="ASYNC_CONSOLE"/>
            <appender-ref ref="JSON_FILE"/>
        </root>
        <logger name="com.llm.gateway" level="INFO" additivity="false">
            <appender-ref ref="ASYNC_CONSOLE"/>
            <appender-ref ref="JSON_FILE"/>
        </logger>
    </springProfile>

</configuration>

